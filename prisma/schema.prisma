generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MediaType {
  MOVIE
  BOOK
  TV_SHOW
  BOARD_GAME
  VIDEO_GAME
}

enum ReviewVisibility {
  PUBLIC
  FRIENDS_ONLY
  PRIVATE
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model MediaItem {
  id              String     @id @default(cuid())
  mediaType       MediaType
  title           String
  slug            String     @unique
  releaseYear     Int?
  description     String?    @db.Text
  imageUrl        String?
  genres          String[]
  imdbRating      Float?
  imdbId          String?
  rtScore         Int?
  rtAudienceScore Int?
  goodreadsRating Float?
  goodreadsId     String?
  openCriticScore Int?
  openCriticId    String?
  metacriticScore Int?
  externalRatingsUpdatedAt DateTime?
  directors       Person[]   @relation("DirectedBy")
  cast            Person[]   @relation("AppearedIn")
  studio          String?
  runtime         Int?
  seasons         Int?
  episodes        Int?
  streamingOn     String[]
  mpaaRating      String?
  authors         Person[]   @relation("AuthoredBy")
  isbn            String?
  publisher       String?
  pageCount       Int?
  designers       Person[]   @relation("DesignedBy")
  publishers      String[]
  minPlayers      Int?
  maxPlayers      Int?
  playTimeMinutes Int?
  platforms       String[]
  reviews         Review[]
  listItems       ListItem[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  @@index([mediaType])
  @@index([title])
  @@index([releaseYear])
}

model Person {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  imageUrl    String?
  bio         String?     @db.Text
  birthYear   Int?
  directed    MediaItem[] @relation("DirectedBy")
  appeared    MediaItem[] @relation("AppearedIn")
  authored    MediaItem[] @relation("AuthoredBy")
  designed    MediaItem[] @relation("DesignedBy")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  @@index([name])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  username        String    @unique
  displayName     String
  bio             String?
  avatarUrl       String?
  isVerified      Boolean   @default(false)
  isAdmin         Boolean   @default(false)
  passwordHash    String?
  googleId        String?   @unique
  googleEmail     String?
  defaultVisibility ReviewVisibility @default(PUBLIC)
  profilePublic   Boolean   @default(true)
  feedTimeframeDays Int?    // admin-set global timeframe; null = all time
  reviews         Review[]
  reactions       Reaction[]
  comments        Comment[]
  friendsInitiated  Friendship[] @relation("FriendInitiator")
  friendsReceived   Friendship[] @relation("FriendReceiver")
  lists           MediaList[]
  notifications   Notification[]
  mediaRequests   MediaRequest[]
  refreshTokens   RefreshToken[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([email])
  @@index([username])
}

model RefreshToken {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model Friendship {
  id          String       @id @default(cuid())
  initiatorId String
  receiverId  String
  status      FriendStatus @default(PENDING)
  initiator   User @relation("FriendInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  receiver    User @relation("FriendReceiver",  fields: [receiverId],  references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([initiatorId, receiverId])
  @@index([receiverId])
  @@index([status])
}

model Review {
  id            String           @id @default(cuid())
  userId        String
  mediaItemId   String
  rating        Int
  isRevisit     Boolean          @default(false)
  previousRating Int?
  reviewText    String?          @db.Text
  spoilerText   String?          @db.Text
  verdict       String?
  visibility    ReviewVisibility @default(PUBLIC)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItem     MediaItem  @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  reactions     Reaction[]
  comments      Comment[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  @@unique([userId, mediaItemId])
  @@index([userId])
  @@index([mediaItemId])
  @@index([visibility])
  @@index([createdAt])
}

model Reaction {
  id        String   @id @default(cuid())
  userId    String
  reviewId  String
  emoji     String   @default("❤️")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, reviewId, emoji])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  reviewId  String
  body      String   @db.Text
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment? @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([reviewId])
}

model MediaList {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  isPublic    Boolean    @default(true)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ListItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model ListItem {
  id          String    @id @default(cuid())
  listId      String
  mediaItemId String
  note        String?
  position    Int       @default(0)
  list        MediaList @relation(fields: [listId], references: [id], onDelete: Cascade)
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id])
  addedAt     DateTime  @default(now())
  @@unique([listId, mediaItemId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  payload   Json
  read      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@index([userId, read])
}

// ─── MEDIA REQUESTS ──────────────────────────────────────

model MediaRequest {
  id           String    @id @default(cuid())
  userId       String
  title        String
  mediaType    MediaType
  directorOrAuthor String?   // optional hint for movies/books
  notes        String?
  requestCount Int       @default(1)  // incremented when others request the same
  flagged      Boolean   @default(false)
  flagNote     String?   // shown to user who requested: "couldn't find this title"
  resolved     Boolean   @default(false)  // true once admin adds the media
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  @@index([mediaType])
  @@index([requestCount])
  @@index([resolved])
}

// ─── ADMIN SETTINGS ──────────────────────────────────────

model AdminSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

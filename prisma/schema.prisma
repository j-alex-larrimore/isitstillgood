generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MediaType {
  MOVIE
  BOOK
  TV_SHOW
  VIDEO_GAME
}

enum ReviewVisibility {
  PUBLIC
  FRIENDS_ONLY
  PRIVATE
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model MediaItem {
  id              String     @id @default(cuid())
  mediaType       MediaType
  title           String
  slug            String     @unique
  releaseYear     Int?
  description     String?    @db.Text
  imageUrl        String?
  genres          String[]

  // External ratings
  imdbRating      Float?
  imdbId          String?
  rtScore         Int?
  rtAudienceScore Int?
  goodreadsRating Float?
  goodreadsId     String?
  openCriticScore Int?
  openCriticId    String?
  metacriticScore Int?
  externalRatingsUpdatedAt DateTime?

  // Movie-specific
  directors       Person[]   @relation("DirectedBy")
  cast            Person[]   @relation("AppearedIn")
  mpaaRating      String?

  // TV Show-specific
  // parentId links a season entry back to its parent show MediaItem.
  // A parent show row has parentId = null and seasons = total count.
  // Each season row has parentId = show's id and seasonNumber = which season.
  parentId        String?
  parent          MediaItem?  @relation("ShowSeasons", fields: [parentId], references: [id])
  seasonEntries   MediaItem[] @relation("ShowSeasons")  // reverse — all seasons of this show
  seasonNumber    Int?        // which season this entry represents (1, 2, 3…)
  seasons         Int?        // total season count — stored on the parent show row only

  // Book-specific
  authors         Person[]   @relation("AuthoredBy")
  seriesName      String?    // e.g. "The Dark Tower"
  seriesNumber    Int?       // e.g. 3

  // Video game-specific
  openCriticId2   String?    // kept for compat, use openCriticId

  // Review is per season for TV shows
  // seasonNumber stored on Review model

  reviews         Review[]
  listItems       ListItem[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([mediaType])
  @@index([title])
  @@index([releaseYear])
}

model Person {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  imageUrl    String?
  bio         String?     @db.Text
  birthYear   Int?
  directed    MediaItem[] @relation("DirectedBy")
  appeared    MediaItem[] @relation("AppearedIn")
  authored    MediaItem[] @relation("AuthoredBy")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  @@index([name])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  username        String    @unique
  displayName     String
  bio             String?
  avatarUrl       String?
  isVerified      Boolean   @default(false)
  isAdmin         Boolean   @default(false)
  passwordHash    String?
  googleId        String?   @unique
  googleEmail     String?
  defaultVisibility ReviewVisibility @default(PUBLIC)
  profilePublic   Boolean   @default(false)  // false = friends only, true = public
  reviews         Review[]
  reactions       Reaction[]
  comments        Comment[]
  friendsInitiated  Friendship[] @relation("FriendInitiator")
  friendsReceived   Friendship[] @relation("FriendReceiver")
  lists           MediaList[]
  notifications   Notification[]
  mediaRequests   MediaRequest[]
  refreshTokens   RefreshToken[]
  sentInvites     InviteToken[]    // invitations this user has sent
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([email])
  @@index([username])
}

model RefreshToken {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model Friendship {
  id          String       @id @default(cuid())
  initiatorId String
  receiverId  String
  status      FriendStatus @default(PENDING)
  initiator   User @relation("FriendInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  receiver    User @relation("FriendReceiver",  fields: [receiverId],  references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([initiatorId, receiverId])
  @@index([receiverId])
  @@index([status])
}

model Review {
  id            String           @id @default(cuid())
  userId        String
  mediaItemId   String
  rating        Int
  dateConsumed  DateTime?        // When the user last read/watched/played this — optional
  seasonNumber  Int?             // TV shows only — null means overall series rating
  isRevisit     Boolean          @default(false)
  previousRating Int?
  reviewText    String?          @db.Text
  spoilerText   String?          @db.Text
  verdict       String?
  visibility    ReviewVisibility @default(PUBLIC)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItem     MediaItem  @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  reactions     Reaction[]
  comments      Comment[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  // Unique per user + media item + season (null season = overall)
  @@unique([userId, mediaItemId, seasonNumber])
  @@index([userId])
  @@index([mediaItemId])
  @@index([visibility])
  @@index([createdAt])
}

model Reaction {
  id        String   @id @default(cuid())
  userId    String
  reviewId  String
  emoji     String   @default("❤️")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, reviewId, emoji])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  reviewId  String
  body      String   @db.Text
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment? @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([reviewId])
}

model MediaList {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  isPublic    Boolean    @default(true)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ListItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model ListItem {
  id          String    @id @default(cuid())
  listId      String
  mediaItemId String
  note        String?
  position    Int       @default(0)
  list        MediaList @relation(fields: [listId], references: [id], onDelete: Cascade)
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id])
  addedAt     DateTime  @default(now())
  @@unique([listId, mediaItemId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  payload   Json
  read      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@index([userId, read])
}

model MediaRequest {
  id               String    @id @default(cuid())
  userId           String
  title            String
  mediaType        MediaType
  directorOrAuthor String?
  notes            String?
  requestCount     Int       @default(1)
  flagged          Boolean   @default(false)
  flagNote         String?
  resolved         Boolean   @default(false)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@index([mediaType])
  @@index([requestCount])
  @@index([resolved])
}

model AdminSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── INVITE TOKENS ────────────────────────────────────────────────────────
// Stores pending email invitations. When someone clicks the link in the email,
// we look up this token to know who invited them and auto-connect as friends.
model InviteToken {
  id          String   @id @default(cuid())
  
  // The user who sent the invite
  inviterId   String
  inviter     User     @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  
  // The email address this invite was sent to
  email       String
  
  // Unique token embedded in the invite link — expires after 7 days
  token       String   @unique @default(cuid())
  
  // Whether this invite has been used (claimed) already
  claimed     Boolean  @default(false)
  
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  
  @@index([token])   // fast lookup when someone clicks the invite link
  @@index([email])   // check if an email already has a pending invite
}
